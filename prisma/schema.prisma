model Courses {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  imageUrl      String
  categoryTags  String[] // Assuming these are just string identifiers for now
  tagIds        String[] @db.ObjectId // Array of Tag IDs
  belongsToIds  String[] @db.ObjectId // Array of BelongsTo IDs (e.g., departments or categories)
  courseData    String[] @db.ObjectId
  projects      Json[]
}
 
model CourseInCourses {
  id  String   @id @default(auto()) @map("_id") @db.ObjectId
  data Json[]
}

model Tags {
  id    String   @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  // Any other fields relevant to a Tag
}
 
model BelongsTo {
  id    String   @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  // Additional fields as needed
}

model UserLearning {
  id    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId String 
  coursesAssigned String[] @db.ObjectId // Array of Course IDs
}

model CourseWork {
  id    String   @id @default(auto()) @map("_id") @db.ObjectId
  videos String[]
  // resources
  // completed 
  // notes
}



