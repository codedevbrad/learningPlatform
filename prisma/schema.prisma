// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// schema.prisma

model Concepts {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  topics      Topic[]   // Define a one-to-many relationship with the Topic model
}

model Topic {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  data        Json[]
  concept     Concepts   @relation(fields: [conceptId], references: [id])
  conceptId   String
}

model Category {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
}